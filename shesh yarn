<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Name - Bootstrap Icons</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        .name-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 20px;
            padding: 2rem;
            color: white;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            backdrop-filter: blur(10px);
            transition: transform 0.3s ease;
        }
        .name-card:hover {
            transform: translateY(-10px);
        }
        .name-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
            opacity: 0.9;
        }
        .name-text {
            font-size: 2.5rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }
        .subtitle {
            font-size: 1.1rem;
            opacity: 0.9;
            margin-bottom: 1.5rem;
        }
        .social-links a {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: white;
            text-decoration: none;
            padding: 0.5rem 1rem;
            border-radius: 25px;
            transition: all 0.3s ease;
            margin: 0.25rem;
        }
        .social-links a:hover {
            background: rgba(255,255,255,0.2);
            transform: translateY(-2px);
        }
    </style>
</head>
<body class="bg-dark d-flex align-items-center justify-content-center min-vh-100 p-3">
    <div class="name-card col-lg-6 col-md-8 col-12">
        <div class="text-center">
            <!-- Main Icon -->
            <i class="bi bi-person-circle name-icon"></i>
            
            <!-- Your Name -->
            <h1 class="name-text mb-2">Jeremiah Dela Mines</h1>
            
            <!-- Subtitle -->
            <p class="subtitle">
                <i class="bi bi-briefcase"></i>
                Full Stack Developer
            </p>
            
            <!-- Social Links -->
            <div class="social-links">
                <a href="#" title="GitHub">
                    <i class="bi bi-github"></i>
                    GitHub
                </a>
                <a href="#" title="LinkedIn">
                    <i class="bi bi-linkedin"></i>
                    LinkedIn
                </a>
                <a href="#" title="Twitter">
                    <i class="bi bi-twitter-x"></i>
                    Twitter
                </a>
                <a href="#" title="Email">
                    <i class="bi bi-envelope"></i>
                    Email
                </a>
            </div>
        </div>
    </div>
</body>
</html>
